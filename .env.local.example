# ----- Anymon environment -----
# Copy this file to .env.local and fill in keys.
# The app runs in demo mode with no AI keys (mock pipeline + in-memory store),
# but sign-in requires either Google OAuth OR guest mode (below).

# =====================================================================
# AUTH (required for the multi-user app)
# =====================================================================
# Random secret used to encrypt sessions. Generate one with:  npx auth secret
AUTH_SECRET=

# Google OAuth credentials (Google Cloud Console -> Credentials -> OAuth client ID,
# type "Web application").
# Authorized redirect URI (local):  http://localhost:3000/api/auth/callback/google
# For phone testing via ngrok, also add:  https://<your-ngrok>.ngrok-free.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Set to 1 to enable a "continue as guest" button (handy before Google is set up).
ALLOW_GUEST=1

# When testing on a phone via ngrok, set this so OAuth callbacks use the right host:
# AUTH_URL=https://<your-ngrok>.ngrok-free.app

# =====================================================================
# GENERATION PIPELINE
# =====================================================================
# Force the mock pipeline (placeholder sprite + sample .glb) even if keys exist.
MOCK_PIPELINE=1

# Anthropic Claude (object identification + educational battle engine)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=                 # optional, default claude-3-5-sonnet-latest

# Google Gemini "Nano Banana Pro" (image-to-image 2D Anymon art)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=           # optional, default gemini-3-pro-image

# ----- 3D model provider (image -> .glb) -----
# Choose one: meshy | trellis | hfspace | mock  (omit to auto-detect from keys)
MODEL_3D_PROVIDER=

# Option A: Meshy (hosted, paid)
MESHY_API_KEY=

# Option B: TRELLIS (free, self-hosted, needs an NVIDIA GPU). See trellis_server/README.md
TRELLIS_API_URL=             # e.g. http://localhost:8000

# Option C: Hugging Face Space "microsoft/TRELLIS.2" (free GPU, no own hardware).
# Get a free token at https://huggingface.co/settings/tokens (READ scope).
# ZeroGPU daily quota: ~5 min free / ~40 min PRO. Set MODEL_3D_PROVIDER=hfspace.
HF_TOKEN=
HF_TRELLIS_SPACE=            # optional, default microsoft/TRELLIS.2

# The Token Company (context compression for battle prompts). Pass-through if empty.
TOKENCOMPANY_API_KEY=
TOKENCOMPANY_API_URL=

# =====================================================================
# DATA
# =====================================================================
# Redis for geospatial state + locks. If empty, an in-memory store is used
# (fine for one machine; resets on restart; not shared across servers).
# Example: redis://default:password@host:6379
#
# REQUIRED ON VERCEL: serverless functions are stateless, so the in-memory
# fallback loses all state between invocations and breaks capture/incubation/
# status polling + multi-user/PvP. Provision a managed serverless Redis.
# Recommended: Upstash for Redis via the Vercel Marketplace, which auto-injects
# a `REDIS_URL` (rediss://) env var into the project:
#   vercel integration add upstash/upstash-kv --plan free -m primaryRegion=iad1
REDIS_URL=
